@startuml
title Diagrama de Sequência - Cadastro de Sessão (MVC + Service + Repository)

actor Admin
participant View as "SessaoView"
participant Controller as "SessaoController"
participant Service as "SessaoService"
participant FilmeRepository as "FilmeRepository"
participant CinemaRepository as "CinemaRepository"
participant SessaoRepository as "SessaoRepository"
database DB as "SQLite"

Admin -> View: cadastrar_sessao(cinema_id, filme_id, data_hora)
activate View

View -> Controller: cadastrar(cinema_id, filme_id, data_hora)
activate Controller

Controller -> Service: cadastrar_sessao(sessao)
activate Service

Service -> CinemaRepository: obter_por_id(cinema_id)
activate CinemaRepository
CinemaRepository -> DB: SELECT * FROM cinemas WHERE id = ?
CinemaRepository --> Service: cinema
deactivate CinemaRepository

Service -> FilmeRepository: obter_por_id(filme_id)
activate FilmeRepository
FilmeRepository -> DB: SELECT * FROM filmes WHERE id = ?
FilmeRepository --> Service: filme
deactivate FilmeRepository

Service -> SessaoRepository: listar_por_cinema(cinema_id)
activate SessaoRepository
SessaoRepository -> DB: SELECT * FROM sessoes WHERE cinema_id = ?
SessaoRepository --> Service: sessoes
deactivate SessaoRepository

Service -> Service: _validar_intervalo_sessoes()

alt Validação OK
  Service -> SessaoRepository: salvar(sessao)
  activate SessaoRepository
  SessaoRepository -> DB: INSERT INTO sessoes
  SessaoRepository --> Service: OK
  deactivate SessaoRepository
  
  Service --> Controller: Sucesso
  Controller --> View: Sucesso
  View --> Admin: Sessão cadastrada com sucesso!
else Erro de Validação
  Service --> Controller: ValueError
  Controller --> View: Erro
  View --> Admin: Erro na validação
end

deactivate Service
deactivate Controller
deactivate View

@enduml
